    # Default props for generic Shorts scene (TitleScene)
    props = {
        "title": "APEX Media",
        "subtitle": "Learn Financial Mastery",
        "tag": "Episode 1",
        "format": "shorts"
    }
    
    try:
        # Render via Remotion CLI
        node_path = "/home/agentuser/.nvm/versions/node/v22.22.1/bin"
        result = subprocess.run(
            [
                f"{node_path}/npx", "remotion", "render",
                "src/index.jsx",
