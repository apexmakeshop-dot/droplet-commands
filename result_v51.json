def send_message(message: str) -> bool:
    """Send message via @Apexinfrabot to Reinier."""
    if not INFRA_BOT_TOKEN:
        logger.warning(f"INFRA_BOT_TOKEN not set. Message: {message}")
        return False
    
    url = f"{TELEGRAM_BOT_URL}{INFRA_BOT_TOKEN}/sendMessage"
    payload = {
        "chat_id": REINIER_CHAT_ID,
        "text": message,
        "parse_mode": "Markdown"
    }
    
    try:
        response = requests.post(url, json=payload, timeout=10)
        if response.status_code == 200:
            logger.info(f"Telegram message sent: {message[:50]}...")
            return True
        else:
            logger.warning(f"Telegram API error: {response.status_code} - {response.text}")
            return False
    except Exception as e:
        logger.error(f"Telegram send failed: {e}")
        return False


def send_alert(task_id: str, video_path: str, duration: float):
    """Send alert for completed animation task."""
    message = f"""🎬 Animation ready
────────────────────────
Task: {task_id}
File: {video_path}
Duration: {duration:.1f}s
────────────────────────
Animation Agent ready for next task."""
    
    send_message(message)


def log_event(message: str):
    """Log timestamped event to daily log."""
    timestamp = datetime.now(timezone.utc).strftime("%Y-%m-%d %H:%M:%S UTC")
    log_line = f"[{timestamp}] {message}"
    logger.info(log_line)


def read_queue():
    """Read queue.json and return task list."""
    try:
        with open(QUEUE_PATH, "r") as f:
            data = json.load(f)
            return data.get("tasks", [])
    except FileNotFoundError:
        logger.warning(f"Queue file not found: {QUEUE_PATH}")
        return []
    except json.JSONDecodeError as e:
        logger.error(f"Invalid JSON in queue: {e}")
        return []


def write_queue(tasks):
    """Write tasks back to queue.json."""
    try:
        with open(QUEUE_PATH, "w") as f:
            json.dump({"tasks": tasks}, f, indent=2)
        logger.info("Queue updated successfully")
    except Exception as e:
        logger.error(f"Failed to write queue: {e}")


def get_audio_duration(audio_file: str) -> float:
    """Get duration of audio file in seconds using ffprobe."""
    try:
        result = subprocess.run(
            [
                "ffprobe", "-v", "quiet", "-print_format", "json",
                "-show_format", audio_file
            ],
            capture_output=True,
            text=True,
            timeout=10
        )
        if result.returncode != 0:
            logger.warning(f"ffprobe failed for {audio_file}: {result.stderr}")
            return None
        
        data = json.loads(result.stdout)
        duration = float(data["format"]["duration"])
        logger.info(f"Audio duration for {audio_file}: {duration:.2f}s")
        return duration
    except Exception as e:
        logger.error(f"Error getting audio duration: {e}")
        return None





def burn_captions(input_path: str, srt_path: str, output_path: str, is_shorts: bool = False) -> bool:
    """
    Burns SRT captions into video using ffmpeg subtitles filter.
    Called after audio normalisation — landscape and Shorts.
    
    If SRT missing or ffmpeg fails: logs warning, copies input to output unchanged.
    Never blocks the pipeline.
    
    Caption style:
    - Font: Arial bold
    - Size: 18 for landscape, 14 for Shorts
    - Colour: white
    - Outline: black 2px
    - Position: bottom-centre (Alignment=2, MarginV=60 landscape, MarginV=1700 Shorts)
    """
    if not os.path.exists(srt_path):
        log_event(f"WARNING: SRT not found at {srt_path} — skipping captions")
        try:
            shutil.copy(input_path, output_path)
        except:
            pass
        return True
    
    try:
        font_size = 14 if is_shorts else 18
        margin_v = 1700 if is_shorts else 60

        cmd = [
            "ffmpeg", "-i", input_path,
            "-vf", f"subtitles={srt_path}:force_style='FontName=Arial,"
            f"FontSize={font_size},Bold=1,PrimaryColour=&HFFFFFF&,"
            f"OutlineColour=&H000000&,Outline=2,"
            f"Alignment=2,MarginV={margin_v}'",
            "-c:a", "copy",
            output_path, "-y"
        ]
        
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=300)
        
        if result.returncode != 0:
            log_event(f"WARNING: Caption burn failed — {result.stderr[:200]}")
            try:
                shutil.copy(input_path, output_path)
            except:
                pass
            return False
        
        log_event(f"Captions burned successfully: {output_path}")
        return True
    except Exception as e:
        log_event(f"WARNING: Caption burn exception — {e}")
        try:
            shutil.copy(input_path, output_path)
        except:
            pass
        return False


def render_animation(task_id: str, audio_file: str, scene_title: str, duration: float, format: str = "landscape") -> str:
    """
    Render animation (Remotion for both landscape and shorts) and combine with audio.
    Returns path to final MP4 or None if failed.
    format: 'landscape' (1280x720) or 'shorts' (1080x1920)
    """
    # Determine output directory based on format
    if format == "shorts":
        output_dir = Path(MEDIA_VIDEO_RAW_DIR) / "shorts"
        output_dir.mkdir(parents=True, exist_ok=True)
    else:
        output_dir = Path(MEDIA_VIDEO_RAW_DIR)
    
    output_path = output_dir / f"{task_id}.mp4"
    
    # Check if output already exists
    if output_path.exists():
        logger.warning(f"Output already exists, skipping: {output_path}")
        return None
    
    # Render silent video based on format
    if format == "shorts":
        # Use Remotion for Shorts (9:16 vertical)
        silent_video = render_remotion_shorts(task_id, duration)
    else:
        # Use Remotion for landscape (16:9)
        silent_video = render_remotion_landscape(task_id, audio_file, scene_title, duration)
    
    if not silent_video or not Path(silent_video).exists():
        logger.error(f"Silent video render failed for {task_id}")
        return None
    
    # Step B: Combine video + audio with ffmpeg
    logger.info(f"Combining video + audio for {task_id}...")
    mixed_output = str(output_path).replace(".mp4", "_mixed.mp4")
    try:
        result = subprocess.run(
            [
                "ffmpeg", "-i", silent_video, "-i", audio_file,
                "-c:v", "copy", "-c:a", "aac", "-shortest",
                mixed_output, "-y"
            ],
            capture_output=True,
            text=True,
            timeout=120  # 2 minutes max for ffmpeg
        )
        
        if result.returncode != 0:
            logger.error(f"ffmpeg combine failed: {result.stderr}")
            return None
        
        logger.info(f"ffmpeg combine completed for {task_id}")
        
    except subprocess.TimeoutExpired:
        logger.error(f"ffmpeg combine timeout for {task_id}")
        return None
    except Exception as e:
        logger.error(f"ffmpeg combine exception: {e}")
        return None
    
    # Step C: Normalise audio to -14 LUFS
    logger.info(f"Normalising audio to -14 LUFS for {task_id}...")
    normalised_path = str(output_path).replace(".mp4", "_norm.mp4")
    try:
        result = subprocess.run(
            [
                "ffmpeg", "-i", mixed_output,
                "-af", "loudnorm=I=-14:TP=-1.5:LRA=11",
                "-c:v", "copy",
                normalised_path, "-y"
            ],
            capture_output=True,
            text=True,
            timeout=120
        )
        
        if result.returncode != 0:
            logger.error(f"Audio normalisation failed: {result.stderr}")
            # Fallback: use mixed output if normalisation fails
            normalised_path = mixed_output
        else:
            logger.info(f"Audio normalisation completed for {task_id}")
            # Clean up intermediate
            try:
                Path(mixed_output).unlink()
            except:
                pass
    except Exception as e:
        logger.error(f"Audio normalisation exception: {e}")
        normalised_path = mixed_output
    
    # Step D: Burn captions (if SRT exists)
    srt_path = None
    # Note: srt_file is only available in render_animation_shorts via task dict
    # Landscape renders don't burn captions yet
    
    if srt_path and Path(srt_path).exists():
        logger.info(f"Burning captions from {srt_path}...")
        burn_captions(normalised_path, srt_path, str(output_path), is_shorts=False)
    else:
        # No SRT provided, use normalised as final
        try:
            shutil.move(normalised_path, str(output_path))
        except:
            pass
    
    # Step E: Confirm output exists
    if not output_path.exists() or output_path.stat().st_size == 0:
        logger.error(f"Output MP4 missing or empty: {output_path}")
        return None
    
    logger.info(f"Final MP4 ready: {output_path} ({output_path.stat().st_size} bytes)")
    return str(output_path)


def render_remotion_landscape(task_id: str, audio_file: str, scene_title: str, duration: float) -> str:
