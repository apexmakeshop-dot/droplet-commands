    Render Remotion landscape scene (1280x720, 16:9).
    Uses default scene sequence: TitleScene → BreakdownScene → OutroScene.
    """
    logger.info(f"Rendering Remotion landscape scene for {task_id}...")
    
    # Calculate total frames for landscape sequence
    # TitleScene: 90 frames, BreakdownScene: 150 frames, OutroScene: 90 frames
    # Total: 330 frames @ 24fps = 13.75 seconds
    total_frames = 330
    
    # Build scenes props JSON
    scenes_props = {
        "scenes": [
            {
                "id": "TitleScene",
                "duration_frames": 90,
                "props": {
                    "title": scene_title,
                    "subtitle": "APEX Media",
                    "tag": "Landscape"
                }
            },
            {
                "id": "BreakdownScene",
                "duration_frames": 150,
                "props": {
                    "title": scene_title,
                    "breakdown": ["50% Needs", "30% Wants", "20% Savings"]
                }
            },
            {
                "id": "OutroScene",
                "duration_frames": 90,
                "props": {
                    "text": "Thank you for watching",
                    "cta": "Subscribe for more"
                }
            }
        ]
    }
    
    # Create temporary silent video path
    temp_silent_path = Path(MEDIA_VIDEO_RAW_DIR) / f"{task_id}_silent.mp4"
    
    try:
        # Step A: Render via Remotion CLI
        node_path = "/home/agentuser/.nvm/versions/node/v22.22.1/bin"
        
        # Build Remotion render command
        cmd = [
            f"{node_path}/npx", "remotion", "render",
            "src/index.jsx",
            "TitleScene",  # Landscape composition ID
            str(temp_silent_path),
            f"--props={json.dumps(scenes_props)}",
            "--codec=h264",
            "--crf=18"
        ]
        
        logger.info(f"Running Remotion render command for {task_id}")
        result = subprocess.run(
            cmd,
            cwd="/home/agentuser/remotion",
